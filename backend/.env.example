PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/tigrinya-app
JWT_SECRET=replace_with_secure_jwt_secret

# Stripe (required for live payments)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx

FRONTEND_URL=http://localhost:5173
ADMIN_EMAILS=admin@example.com

# Optional Redis/BullMQ
REDIS_URL=redis://127.0.0.1:6379
ENABLE_EMAIL_QUEUE=false

# Optional SMTP for purchase emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
EMAIL_FROM=Tigrinya Kids <your_email@example.com>
